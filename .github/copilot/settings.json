{
  "version": 1,
  "model": {
    "default": "claude-sonnet-4-6"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(chmod 777 *)",
      "Bash(git push --force origin main)",
      "Bash(git push -f origin main)",
      "Bash(git push --force origin master)",
      "Bash(git reset --hard origin/main)",
      "Bash(git clean -fdx)",
      "Bash(git config --global *)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(cargo publish*)",
      "Bash(twine upload*)",
      "Bash(docker push *)",
      "Bash(kubectl delete *)",
      "Bash(terraform destroy*)",
      "Bash(terraform apply -auto-approve*)",
      "Bash(aws * delete*)",
      "Bash(gcloud * delete*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/credentials*)",
      "Edit(./.github/workflows/**)",
      "Edit(./infra/**)",
      "Edit(**/*.tf)",
      "Edit(**/*.tfvars)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(gh pr merge *)",
      "Bash(gh release *)"
    ]
  },
  "telemetry": {
    "enabled": false
  }
}
